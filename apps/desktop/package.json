{
  "name": "@nchub/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "NetworkChuck Hub desktop app",
  "homepage": "https://github.com/meteor4real/networkchuckhub",
  "author": {
    "name": "NetworkChuck Hub",
    "email": "hub@example.com"
  },
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "icons": "node scripts/generate-icons.mjs",
    "package": "npm run icons && npm run build && electron-builder",
    "package:win": "npm run icons && npm run build && electron-builder --win",
    "package:mac": "npm run icons && npm run build && electron-builder --mac",
    "package:linux": "npm run icons && npm run build && electron-builder --linux"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "node-pty": "^1.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.163.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.163.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "31.7.7",
    "electron-builder": "^24.13.3",
    "png-to-ico": "^2.1.8",
    "png2icons": "^2.0.1",
    "sharp": "^0.33.4",
    "typescript": "^5.5.0",
    "vite": "^5.3.0",
    "vite-plugin-electron": "^0.28.7",
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}
