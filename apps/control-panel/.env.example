# Database (already configured in Vercel)
# IMPORTANT: when using Supabase, prefer the *transaction-mode* pooler URL
# (port 6543 on *.pooler.supabase.com). The session-mode pooler (port 5432)
# is capped at 15 simultaneous clients and breaks under serverless load
# with EMAXCONNSESSION.
POSTGRES_URL=

# Optional explicit override. If set, takes precedence over POSTGRES_URL.
# Use this if you want to point ChuckHub at a different Postgres than the
# one Vercel auto-wired.
CHUCKHUB_POSTGRES_URL=

# GitHub
GITHUB_TOKEN=
GITHUB_USERNAME=theNetworkChuck

# Vercel
VERCEL_TOKEN=
VERCEL_TEAM_ID=

# Supabase (management API)
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=

# n8n self-hosted
N8N_BASE_URL=
N8N_API_KEY=

# Proxmox
PROXMOX_BASE_URL=
PROXMOX_TOKEN_ID=
PROXMOX_TOKEN_SECRET=

# Portainer
PORTAINER_BASE_URL=
PORTAINER_API_KEY=

# Cloudflare
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Tailscale
TAILSCALE_API_KEY=
TAILSCALE_TAILNET=

# Twingate
TWINGATE_API_KEY=
TWINGATE_NETWORK=

# Pi-hole v6
PIHOLE_BASE_URL=
PIHOLE_PASSWORD=

# Frigate
FRIGATE_BASE_URL=

# Traefik
TRAEFIK_BASE_URL=

# YouTube Data API
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=UC0ZTPkdxlAKf-V33tqXwi3Q

# ZimaCube SSH (host:port, user, key path on server)
ZIMA_SSH_HOST=
ZIMA_SSH_USER=

# Claude Code VPS terminal bridge
CLAUDE_SSH_HOST=
CLAUDE_SSH_USER=

# Auth — Postgres-backed sessions (built-in)
# OPTIONAL. If unset, ChuckHub auto-generates a 96-char secret on first
# run and persists it in the chuckhub_meta table. Set this only if you
# want to override the auto-generated value (e.g. share sessions across
# environments). Must be at least 16 chars.
# Generate with: openssl rand -hex 32
CHUCKHUB_SECRET=

# OPTIONAL master code used by the account-recovery form on /login.
# Defaults to "2089" if not set.
CHUCKHUB_MASTER_CODE=
