{
  "name": "networkchuck-hub",
  "version": "4.0.0",
  "private": true,
  "description": "NetworkChuck Hub — unified personal-ops command center. Download page (web) + desktop app.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=@nchub/web",
    "build:web": "npm run build --workspace=@nchub/web",
    "dev:control-panel": "npm run dev --workspace=@nchub/control-panel",
    "build:control-panel": "npm run build --workspace=@nchub/control-panel",
    "dev:desktop": "npm run dev --workspace=@nchub/desktop",
    "build:desktop": "npm run build --workspace=@nchub/desktop",
    "package:desktop": "npm run package --workspace=@nchub/desktop",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "engines": {
    "node": ">=20"
  }
}
